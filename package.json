{
  "private": true,
  "scripts": {
    "analyze": "cross-env ANALYZE=true next build",
    "analyze:server": "cross-env BUNDLE_ANALYZE=server next build",
    "analyze:browser": "cross-env BUNDLE_ANALYZE=browser next build",
    "vercel-build": "yarn run prebuild && next build && yarn run postbuild",
    "dev": "yarn run prebuild && next dev",
    "build": "yarn run prebuild && next build",
    "prebuild": "node scripts/generate-sw.mjs",
    "build:development": "NODE_ENV=development env-cmd -f .env.development yarn run prebuild && env-cmd -f .env.development next build",
    "start:development": "env-cmd -f .env.development next start",
    "build:staging": "NODE_ENV=staging env-cmd -f .env.staging yarn run prebuild && env-cmd -f .env.staging next build",
    "start:staging": "env-cmd -f .env.staging next start",
    "build:production": "NODE_ENV=production env-cmd -f .env.production yarn run prebuild && env-cmd -f .env.production next build",
    "start:production": "NODE_ENV=production env-cmd -f .env.production next start",
    "postbuild": "next-sitemap",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "playwright test --debug",
    "scan": "npx react-scan@latest localhost:3000",
    "audit:design-system": "node scripts/design-system-audit.js",
    "audit:weekly-report": "node scripts/generate-weekly-audit-report.js",
    "audit:detect-violations": "node scripts/automated-violation-detection.js",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "dependencies": {
    "@headlessui/react": "^1.7.10",
    "@heroicons/react": "^1.0.6",
    "@sentry/nextjs": "^7.105.0",
    "@tailwindcss/aspect-ratio": "^0.4.2",
    "@tailwindcss/forms": "^0.5.3",
    "@tailwindcss/typography": "^0.5.9",
    "autoprefixer": "^10.4.20",
    "axios": "^1.4.0",
    "cloudinary": "^2.7.0",
    "clsx": "^2.1.1",
    "critters": "^0.0.25",
    "cssnano": "^7.0.6",
    "date-fns": "^2.29.3",
