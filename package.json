{
  "private": true,
  "engines": {
    "node": "22.x",
    "yarn": ">=4.0.0"
  },
  "scripts": {
    "analyze": "cross-env ANALYZE=true next build",
    "analyze:browser": "cross-env BUNDLE_ANALYZE=browser next build",
    "analyze:server": "cross-env BUNDLE_ANALYZE=server next build",
    "analyze:experimental": "next experimental-analyze",
    "analyze:webpack": "cross-env ANALYZE=true next build --webpack",
    "analyze:cli": "node scripts/analyze-bundles-cli.mjs",
    "analyze:api": "node scripts/analyze-bundles-api.mjs",
    "upgrade": "next upgrade",
    "build": "next build",
    "build:development": "NODE_ENV=development env-cmd -f .env.development yarn run prebuild && env-cmd -f .env.development next build",
    "build:production": "NODE_ENV=production env-cmd -f .env.production yarn run prebuild && env-cmd -f .env.production next build",
    "build:staging": "NODE_ENV=staging env-cmd -f .env.staging yarn run prebuild && env-cmd -f .env.staging next build",
    "dev": "next dev",
    "dev:inspect": "next dev --inspect",
    "lint": "eslint .",
    "prebuild": "node scripts/generate-sw.mjs && node scripts/generate-robots.mjs",
    "prepare": "husky",
    "scan": "npx react-scan@latest localhost:3000",
    "i18n:sync": "node scripts/sync-locales.mjs",
    "i18n:check": "i18n-check -s ca --locales messages --only invalidKeys,missingKeys -i \"Utils.Calendar.moreInfoHtml\" -i \"Utils.StringHelpers.capitalizePrepositions.*\" -i \"Utils.StringHelpers.feminineExceptions.*\" -i \"Utils.StringHelpers.masculineExceptions.*\"",
    "i18n:validate": "node scripts/validate-i18n-placeholders.mjs",
    "lighthouse:ci": "lhci autorun --config=.lighthouserc.json",
    "start": "next start",
    "start:development": "env-cmd -f .env.development next start",
    "start:production": "NODE_ENV=production env-cmd -f .env.production next start",
    "start:staging": "env-cmd -f .env.staging next start",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:ui": "playwright test --ui",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "eslint --fix"
    ],
    "messages/*.json": [
      "yarn i18n:check",
      "yarn i18n:validate"
    ]
  },
  "dependencies": {
    "@fortedigital/nextjs-cache-handler": "^3.2.0",
    "@headlessui/react": "^2.2.10",
    "@heroicons/react": "^2.2.0",
    "@sentry/nextjs": "10.56.0",
    "@tailwindcss/aspect-ratio": "^0.4.2",
    "@tailwindcss/forms": "^0.5.11",
    "@tailwindcss/typography": "^0.5.19",
    "autoprefixer": "^10.5.0",
    "cssnano": "^8.0.1",
    "date-fns": "^4.4.0",
    "fast-xml-parser": "^5.7.0",
    "feed": "^5.2.1",
    "next": "16.2.7",
    "next-intl": "^4.13.0",
    "postcss": "^8.5.15",
    "react": "19.2.7",
    "react-day-picker": "^9.14.0",
    "react-dom": "19.2.7",
    "react-select": "^5.10.2",
    "react-share": "^5.3.0",
    "redis": "^5.12.1",
    "sharp": "^0.34.5",
    "swr": "^2.4.1",
    "tailwindcss": "3.3.6",
    "undici": "^7.25.0",
    "web-vitals": "^5.3.0",
    "zod": "3.25.76",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@eslint-react/eslint-plugin": "^5.8.8",
    "@eslint/compat": "^2.1.0",
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^10.0.1",
    "@lhci/cli": "^0.15.1",
    "@lingual/i18n-check": "^0.9.5",
    "@next/bundle-analyzer": "^16.2.6",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/context-async-hooks": "^2.7.1",
    "@opentelemetry/core": "^2.7.1",
    "@opentelemetry/sdk-trace-base": "^2.7.1",
    "@playwright/test": "1.60.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/jest": "^30.0.0",
    "@types/jsdom": "^28.0.3",
    "@types/node": "^25.6.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.60.0",
    "@typescript-eslint/parser": "^8.60.0",
    "@vitejs/plugin-react": "^6.0.2",
    "@vitest/coverage-v8": "^4.1.7",
    "babel-plugin-react-compiler": "^19.1.0-rc.1",
    "baseline-browser-mapping": "^2.10.33",
    "cheerio": "^1.2.0",
    "cross-env": "^10.1.0",
    "env-cmd": "^10.1.0",
    "eslint": "10",
    "eslint-config-next": "^16.2.6",
    "eslint-plugin-react-hooks": "^7.1.1",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "lint-staged": "^17.0.6",
    "next-sitemap": "^4.2.3",
    "typescript": "5.9.3",
    "vite-tsconfig-paths": "^4.3.0",
    "vitest": "4.1.7"
  },
  "packageManager": "yarn@4.12.0",
  "browserslist": {
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ],
    "production": [
      "chrome >= 122",
      "edge >= 122",
      "firefox >= 125",
      "safari >= 17.4",
      "ios_saf >= 17.4"
    ]
  },
  "resolutions": {
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3"
  }
}
