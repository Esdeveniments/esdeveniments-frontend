# Environment variables for esdeveniments-frontend.
#
# Copy to .env.local for local dev and fill in real values. This file is the
# source of truth for what each deploy target (Coolify staging/prod) must have.
# Never commit real values — only placeholders belong here.
#
# NEXT_PUBLIC_* are inlined into the client bundle AT BUILD TIME. In Coolify
# they must be marked build-time (and are declared as ARG in the Dockerfile).
# Everything else is read at runtime by the Node server.

# ── Core ────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://www.esdeveniments.cat
NEXT_PUBLIC_API_URL=https://api.esdeveniments.cat/api
NEXT_PUBLIC_CONTACT_EMAIL=hola@esdeveniments.cat
HMAC_SECRET=your-hmac-secret
REVALIDATE_SECRET=your-revalidate-secret
BUILD_VERSION=local

# ── Web Push (added in the install-first PWA work) ──────────────────
# Generate a keypair with:  npx web-push generate-vapid-keys
# VAPID_PUBLIC_KEY and NEXT_PUBLIC_VAPID_PUBLIC_KEY MUST be the same public key.
# In Coolify, mark NEXT_PUBLIC_VAPID_PUBLIC_KEY as build-time; the rest runtime.
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key
VAPID_EMAIL=hola@esdeveniments.cat
# Dedicated bearer secret for the broadcast route — NOT reused from REVALIDATE_SECRET.
PUSH_SEND_SECRET=your-push-send-secret

# ── Database (Turso) ────────────────────────────────────────────────
TURSO_DATABASE_URL=libsql://your-db.turso.io
TURSO_AUTH_TOKEN=your-turso-token

# ── Cache ───────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Analytics / Ads (client, build-time) ────────────────────────────
NEXT_PUBLIC_GOOGLE_ANALYTICS=
NEXT_PUBLIC_GOOGLE_ADS=
NEXT_PUBLIC_GOOGLE_MAPS=
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=

# ── Sentry ──────────────────────────────────────────────────────────
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=

# ── Integrations ────────────────────────────────────────────────────
GOOGLE_PLACES_API_KEY=
DEEPL_API_KEY=
NEW_EVENT_EMAIL_URL=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_TIKTOK_CLIENT_KEY=
NEXT_PUBLIC_TIKTOK_REDIRECT_URI=
TIKTOK_CLIENT_SECRET=

# ── CDN / Infra ─────────────────────────────────────────────────────
CLOUDFLARE_ZONE_ID=
CLOUDFLARE_API_TOKEN=
CLOUDFRONT_DISTRIBUTION_ID=
LHCI_GITHUB_APP_TOKEN=
